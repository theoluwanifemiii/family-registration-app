SMS_TEST_MODE=false

# ── Server ────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Admin ─────────────────────────────────────────────────────
VITE_ADMIN_PIN=1234
