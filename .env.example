# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=notifications@mail.usemomentos.xyz
FROM_NAME=Family Month 2026

# ── SMS (Termii) ──────────────────────────────────────────────
TERMII_API_KEY=your_termii_api_key_here
